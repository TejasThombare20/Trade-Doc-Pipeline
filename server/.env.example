# ---- Required ----
DATABASE_URL=postgresql://postgres:password@localhost:5432/nova
OPENAI_API_KEY=sk-your-openai-key-here

# ---- Optional (defaults shown) ----
ENV=dev
RUN_ENV=local          # "local" stores uploads in public/ folder; "cloud" uses S3
LOG_LEVEL=INFO

# OpenAI models
OPENAI_MODEL_VISION=gpt-4o
OPENAI_MODEL_REASONING=gpt-4o
OPENAI_MODEL_CHEAP=gpt-4o-mini

# Storage: "local" (default) or "s3"
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=public

# S3 (required when STORAGE_BACKEND=s3)
# S3_BUCKET=
# S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT_URL=

# Pipeline safety
COST_CAP_USD_PER_RUN=0.50
MAX_RETRIES_PER_NODE=2
LOW_CONFIDENCE_THRESHOLD=0.70

# Upload limits
MAX_UPLOAD_BYTES=26214400

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Auth (dummy JWT for Part 1)
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
SESSION_COOKIE_NAME=nova_session
SESSION_TTL_SECONDS=604800
